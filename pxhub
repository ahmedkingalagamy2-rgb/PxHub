local UltimateModeActive = false
local LateralWelding = false

local LateralActivationLabel = Instance.new("TextLabel")
LateralActivationLabel.Size = UDim2.new(1, 0, 0, 50)
LateralActivationLabel.Position = UDim2.new(0, 0, 0.4, 0)
LateralActivationLabel.BackgroundTransparency = 1
LateralActivationLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
LateralActivationLabel.Text = "Lateral Activation"
LateralActivationLabel.Font = Enum.Font.SourceSansBold; LateralActivationLabel.TextSize = 36
LateralActivationLabel.Visible = false
LateralActivationLabel.Parent = ScreenGui

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.G then
        UltimateModeActive = not UltimateModeActive
        if UltimateModeActive then
            -- تحويل الواجهة فوراً للوضع الوحشي المظلم بحدود نارية فخمة
            MainGUI.BackgroundColor3 = Color3.fromRGB(5, 0, 0)
            Navbar.Visible = false
            LateralActivationLabel.Visible = true
            task.wait(2)
            LateralActivationLabel.Visible = false
            
            -- مسح محتويات الصفحة مؤقتاً لعرض ميزات الـ Activation
            for _, p in pairs(TabPages) do p.Visible = false end
            TabPages["favorite"].Visible = true
        else
            -- إلغاء الوضع الوحشي وإرجاع الهيكل الطبيعي للـ Hub
            MainGUI.BackgroundColor3 = NormalBackground
            Navbar.Visible = true
            TabPages["favorite"].Visible = false
            TabPages["combat"].Visible = true
        end
    end
end)

